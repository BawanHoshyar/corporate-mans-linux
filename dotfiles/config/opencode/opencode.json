{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5 Coder 7B (default agent)"
        },
        "huihui_ai/gpt-oss-abliterated:20b": {
          "name": "GPT-OSS 20B Abliterated (uncensored agent)"
        },
        "WhiteRabbitNeo/Llama-3.1-WhiteRabbitNeo-2-8B:latest": {
          "name": "WhiteRabbitNeo 8B (chat only, no tools)"
        }
      }
    }
  }
}
